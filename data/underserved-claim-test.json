  "models": {
    "gapScore_formula": "inOnlyChannels / inChannels (0-1, higher = more underserved)",
    "uk_gap_formula": "gbChannels === 0 ? full_gap : partial_gap",
    "channelValue_formula": "queriesAppeared * avgGapScoreOfAppearedQueries",
    "topicGapAggregation": "mean(gapScore) across queries in that topic cluster"
  },
  "featureStoreSchema": {
    "description": "Structuring this data for ML models requires joining it with video-level breakout scores. Schema below is the target D1 table for the full pipeline.",
    "tableName": "niche_intelligence",
    "primaryKey": "video_id + snapshot_date",
    "columns": [
      {"name": "snapshot_date", "type": "DATE", "use": "Partition key for time-series. Enables daily/weekly delta tracking."},
      {"name": "video_id", "type": "TEXT", "use": "YouTube video ID. Joins to breakout_score from channel-level harvest."},
      {"name": "channel_id", "type": "TEXT", "use": "YouTube channel ID. Joins to channel_metadata table for subs, country."},
      {"name": "query", "type": "TEXT", "use": "The search query that found this video. Enables topic clustering."},
      {"name": "topic_cluster", "type": "TEXT", "use": "Mapped from query taxonomy (philosophy, deity, practice, taboo, historical)."},
      {"name": "region", "type": "TEXT", "use": "IN, US, or GB. The region this result came from."},
      {"name": "search_rank", "type": "INTEGER", "use": "Position in search results (1-15). Higher rank = more relevant to query."},
      {"name": "appears_in_IN", "type": "BOOLEAN", "use": "Found in Indian region search."},
      {"name": "appears_in_US", "type": "BOOLEAN", "use": "Found in US region search."},
      {"name": "appears_in_GB", "type": "BOOLEAN", "use": "Found in UK region search."},
      {"name": "gap_score", "type": "FLOAT", "use": "Computed: 1 if only in IN, 0 if in all three. Continuous measure of underservedness."},
      {"name": "channel_visibility_class", "type": "TEXT", "use": "IN_only, IN_US, IN_GB, US_only, GB_only, all_three. Categorical target for channel-level models."},
      {"name": "breakout_score", "type": "FLOAT", "use": "Joined from channel harvest: (views/days) / channel_median_views_per_day. NULL until channel harvest is run."},
      {"name": "is_breakout", "type": "BOOLEAN", "use": "breakout_score in top quartile for this channel. NULL until computed."}
    ],
    "modelUseCases": [
      "Logistic regression: predict is_breakout from gap_score + topic + region features. Tests whether underserved topics actually break out more.",
      "Channel recommendation: given a topic cluster with high gap_score, rank similar channels by their visibility class to find peers for competitive analysis.",
      "Time-series: as snapshots accumulate, model gap_score trends. A topic with decreasing gap_score signals saturation. Increasing gap_score = widening opportunity.",
      "Feature for content planning: topic clusters sorted by (gap_score * breakout_rate) produce a ranked content roadmap where each row is a validated topic with known market gap."
    ],
    "joinsRequired": [
      {"table": "channel_metadata", "key": "channel_id", "columns": ["subscriber_count", "video_count", "country", "topic_affinities"]},
      {"table": "channel_video_harvest", "key": "video_id", "columns": ["title_features", "thumbnail_features", "hook_type", "duration", "breakout_score"]},
      {"table": "gap_map_history", "key": "query + date", "columns": ["gap_score_over_time", "trend_direction"]}
    ],
    "nextStep": "Curate 20-40 channel list (step 2 from highsignalspec.md), run full video harvest, compute breakout scores, join with this gap data, then fit a simple model."
  }
}