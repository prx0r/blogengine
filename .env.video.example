# ── YouTube Data API (Google Cloud, free quota: 10k units/day) ──
YOUTUBE_API_KEY=

# ── LLM: DeepSeek V4 Flash (default, highest quality) ──
# No config needed — code defaults to https://opencode.ai/zen/go/v1 + deepseek-v4-flash
# Override only if you want a different model:
# VIDEO_LLM_BASE_URL=https://opencode.ai/zen/go/v1
# VIDEO_LLM_API_KEY=
# VIDEO_LLM_MODEL=deepseek-v4-flash
# VIDEO_VISION_BASE_URL=https://opencode.ai/zen/go/v1
# VIDEO_VISION_MODEL=deepseek-v4-flash

# ── Fallback: Cloudflare Workers AI (free, lower quality) ──
# Set CF_ACCOUNT_ID + CF_API_TOKEN and code auto-switches to Workers AI.
# CF_ACCOUNT_ID=
# CF_API_TOKEN=

# ── Private YouTube Analytics (OAuth, for beat-level retention) ──
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# Or use a short-lived access token instead of the three OAuth values above:
YOUTUBE_ANALYTICS_ACCESS_TOKEN=
