{
  "name": "blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "generate": "node scripts/generate.mjs",
    "generate:audio": "node scripts/generate-audio.mjs",
    "generate:graph": "node scripts/generate-graph-json.mjs",
    "build:pages": "node scripts/build.mjs",
    "index-content": "node scripts/index-content.mjs",
    "extract-picatrix": "node scripts/extract-picatrix.mjs",
    "proxy": "node server/proxy.mjs",
    "validate:content": "npx tsx scripts/validate-content.ts",
    "db:init": "wrangler d1 execute atlas-db --file=src/atlas/db/schema.sql",
    "atlas:deploy": "wrangler pages deploy",
    "atlas:dev": "next dev",
    "eval:run": "npx tsx tests/eval/run-eval.ts",
    "cf:build": "node scripts/generate-graph-json.mjs && next build && opennextjs-cloudflare build",
    "cf:deploy": "npm run cf:build && opennextjs-cloudflare deploy",
    "cf:preview": "npm run cf:build && wrangler dev",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@xyflow/react": "^12.11.1",
    "caelus": "^0.23.0",
    "caelus-birth": "^0.23.0",
    "caelus-wheel": "^0.23.0",
    "cheerio": "^1.2.0",
    "cookie": "^2.0.1",
    "dagre": "^0.8.5",
    "next": "16.2.10",
    "openai": "^4.0.0",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260704.1",
    "@tailwindcss/postcss": "^4",
    "@types/cookie": "^0.6.0",
    "@types/dagre": "^0.7.54",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "js-yaml": "^5.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.107.0"
  }
}
