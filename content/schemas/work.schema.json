{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Work",
  "description": "A scholarly work (paper, thesis, book chapter) in the Hermes research corpus",
  "type": "object",
  "required": ["work_id", "schema_version", "title", "authors"],
  "properties": {
    "work_id": { "type": "string", "pattern": "^work:[a-z0-9_-]+$" },
    "schema_version": { "type": "integer", "minimum": 1 },
    "title": { "type": "string" },
    "authors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "author_id": { "type": "string", "pattern": "^author:[a-z0-9_-]+$" }
        }
      }
    },
    "publication": {
      "type": "object",
      "properties": {
        "year": { "type": "integer" },
        "type": { "type": "string", "enum": ["article", "thesis", "book", "book_chapter", "essay", "preprint", "conference"] },
        "journal": { "type": "string" },
        "publisher": { "type": "string" },
        "language": { "type": "string" }
      }
    },
    "identifiers": {
      "type": "object",
      "properties": {
        "doi": { "type": ["string", "null"] },
        "openalex_id": { "type": ["string", "null"] },
        "isbn": { "type": ["string", "null"] }
      }
    },
    "topics": { "type": "array", "items": { "type": "string" } },
    "tradition": { "type": "array", "items": { "type": "string" } },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "predicate": { "type": "string" },
          "target_id": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "assets": {
      "type": "object",
      "properties": {
        "pdf_path": { "type": "string" },
        "text_path": { "type": "string" },
        "source_url": { "type": "string" }
      }
    },
    "provenance": {
      "type": "object",
      "properties": {
        "access_status": { "type": "string", "enum": ["open", "paywalled", "request_only", "rights_check"] },
        "oa_status": { "type": "string" },
        "license": { "type": ["string", "null"] },
        "version": { "type": "string" },
        "host_type": { "type": "string" },
        "sha256": { "type": "string" },
        "page_count": { "type": "integer" },
        "file_size_bytes": { "type": "integer" },
        "retrieved_at": { "type": "string", "format": "date-time" },
        "validation_confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "analysis": {
      "type": "object",
      "properties": {
        "summary": { "type": "string" },
        "argument": { "type": "string" },
        "quality_score": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
