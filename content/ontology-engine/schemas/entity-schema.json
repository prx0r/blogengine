{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ontology Entity",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "sanskrit": {
      "type": "string"
    },
    "tradition": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "deity",
        "concept",
        "principle",
        "tattva",
        "state",
        "method",
        "practice",
        "process",
        "event",
        "sefirah"
      ]
    },
    "canonical_id": {
      "type": "string"
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "canonical_relation": {
            "type": "string"
          }
        }
      }
    },
    "visual_form": {
      "type": "object",
      "properties": {
        "archetype": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "mappings": {
      "type": "object"
    },
    "hebrew": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "name",
    "tradition",
    "type"
  ]
}
